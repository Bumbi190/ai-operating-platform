{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "familje-stunden/canon/cca-params.schema.json",
  "title": "CCA Params",
  "type": "object",
  "required": ["canon_version", "project_id", "signature_colors", "foreign_share_min", "loosen_factor_generated", "provenance_epsilon", "kmeans"],
  "properties": {
    "canon_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "project_id": { "type": "string", "minLength": 1 },
    "note": { "type": "string" },
    "signature_colors": {
      "type": "object",
      "additionalProperties": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
    },
    "foreign_share_min": { "type": "number", "minimum": 0, "maximum": 1 },
    "loosen_factor_generated": { "type": "number", "minimum": 1 },
    "provenance_epsilon": { "type": "number", "minimum": 0, "maximum": 1 },
    "presence_floor": { "type": "number", "minimum": 0, "maximum": 1 },
    "neutral_tolerance": {
      "type": "object",
      "properties": {
        "white_min": { "type": "integer" },
        "black_max": { "type": "integer" }
      }
    },
    "kmeans": {
      "type": "object",
      "required": ["k", "max_iter", "quantize_bits", "downsample_max_px"],
      "properties": {
        "k": { "type": "integer", "minimum": 2 },
        "max_iter": { "type": "integer", "minimum": 1 },
        "quantize_bits": { "type": "integer", "minimum": 1, "maximum": 8 },
        "downsample_max_px": { "type": "integer", "minimum": 16 }
      }
    }
  }
}
