      { "id": "TV-SYMBOL",    "rule": "minst en symbol ur months[current].symbols förekommer i copy", "severity": "warn" },
      { "id": "TV-CROSSTHEME","rule": "inga symboler/ord från andra månaders teman (helord-matchning)", "severity": "block" },
